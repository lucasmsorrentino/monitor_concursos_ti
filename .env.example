# =====================================================================
# TELEGRAM
# =====================================================================
# Token unico do bot (uma instancia pode enviar para varias areas/chats)
TELEGRAM_TOKEN=seu_token_telegram

# =====================================================================
# LLM — escolha UMA das tres opcoes abaixo (LLM_MODEL define o backend)
# =====================================================================

# --- Opcao 1: Ollama local (padrao, custo zero, usa CPU/GPU local) ---
LLM_MODEL=llama3.1
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Opcao 2: API remota via LiteLLM (rapida e precisa, custo por token) ---
# Descomente o modelo e exporte a API key do provider correspondente.
# LLM_MODEL=anthropic/claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sua_api_key
# ...ou outros providers:
# LLM_MODEL=openai/gpt-4o-mini
# OPENAI_API_KEY=sua_api_key
# LLM_MODEL=minimax/MiniMax-M2
# MINIMAX_API_KEY=sua_api_key

# --- Opcao 3: Claude Code CLI (usa a assinatura local, custo marginal zero) ---
# Requer `claude` no PATH, autenticado via OAuth. Latencia alta (segundos).
# Aliases disponiveis: haiku (default), sonnet, opus.
# LLM_MODEL=claude-cli:haiku

# --- Configuracoes comuns (aplicam-se aos tres backends) ---
OLLAMA_TIMEOUT_S=120
OLLAMA_RETRIES=2
OLLAMA_RETRY_DELAY_S=2

# =====================================================================
# ALVOS DE MONITORAMENTO
# =====================================================================
# Modo multi-area (recomendado)
# IMPORTANTE: python-dotenv nao suporta multiline — JSON deve ficar em UMA linha
MONITOR_TARGETS_JSON=[{"area": "TI", "display_name": "Tecnologia da Informacao", "url": "https://blog.grancursosonline.com.br/concursos-ti/", "chat_ids": ["SEU_CHAT_ID"], "keywords_include": ["ti", "tecnologia", "informacao", "sistemas"], "keywords_exclude": ["sociologia", "artes", "pedagogia"]}, {"area": "EDUCACAO", "display_name": "Educacao", "url": "https://blog.grancursosonline.com.br/concursos-educacao/", "chat_ids": ["CHAT_ID_NAMORADA"], "keywords_include": [], "keywords_exclude": []}]

# Modo legado (single-area) — usado apenas se MONITOR_TARGETS_JSON estiver ausente
# URL_ALVO=https://blog.grancursosonline.com.br/concursos-ti/
# TELEGRAM_CHAT_ID=seu_chat_id
# KEYWORDS_INCLUDE=ti,tecnologia,informacao,sistemas
# KEYWORDS_EXCLUDE=sociologia,artes,pedagogia

# =====================================================================
# AGENDAMENTO
# =====================================================================
# Nao usado pelo main.py (que roda uma vez e sai). Agendamento diario e
# feito pelo Windows Task Scheduler — veja scripts/install_schedule.ps1.
# HORARIO_EXECUCAO=03:00
