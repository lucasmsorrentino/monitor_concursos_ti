# Telegram base (mesmo token para todas as areas)
TELEGRAM_TOKEN=seu_token_telegram

# LLM — escolha UM dos modos abaixo:

# Modo 1: Ollama local (padrão)
LLM_MODEL=llama3.1
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Modo 2: API remota via LiteLLM (descomente e configure)
# LLM_MODEL=minimax/MiniMax-M2
# MINIMAX_API_KEY=sua_api_key_aqui

# Configurações comuns
OLLAMA_TIMEOUT_S=120
OLLAMA_RETRIES=2
OLLAMA_RETRY_DELAY_S=2

# Scheduler
HORARIO_EXECUCAO=08:00

# Modo legado (single-area)
# URL_ALVO=https://blog.grancursosonline.com.br/concursos-ti/
# TELEGRAM_CHAT_ID=seu_chat_id
# KEYWORDS_INCLUDE=ti,tecnologia,informacao,sistemas
# KEYWORDS_EXCLUDE=sociologia,artes,pedagogia

# Modo multi-area (recomendado)
# IMPORTANTE: python-dotenv nao suporta multiline — JSON deve ficar em UMA linha
# URLs de blog do Gran: concursos-ti/, concursos-educacao/, etc.
MONITOR_TARGETS_JSON=[{"area": "TI", "display_name": "Tecnologia da Informacao", "url": "https://blog.grancursosonline.com.br/concursos-ti/", "chat_ids": ["SEU_CHAT_ID"], "keywords_include": ["ti", "tecnologia", "informacao", "sistemas"], "keywords_exclude": ["sociologia", "artes", "pedagogia"]}, {"area": "EDUCACAO", "display_name": "Educacao", "url": "https://blog.grancursosonline.com.br/concursos-educacao/", "chat_ids": ["CHAT_ID_NAMORADA"], "keywords_include": [], "keywords_exclude": []}]
